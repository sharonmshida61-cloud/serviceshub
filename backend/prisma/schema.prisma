// ==========================================================================
// LocalServices Platform — Database Schema
// Uses SQLite for zero-config local development.
// To move to Postgres for production: change provider to "postgresql" and
// set DATABASE_URL to a postgres connection string — no model changes needed.
// ==========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// USERS & ROLES
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String
  phone         String?
  roles         String   @default("[\"CUSTOMER\"]") // JSON array: ["CUSTOMER"], ["BUSINESS_OWNER"], or ["CUSTOMER", "BUSINESS_OWNER"]
  currentRole   String   @default("CUSTOMER") // Current active role for UI purposes
  role          String   @default("CUSTOMER") // Legacy field for backward compatibility
  avatarUrl     String?
  createdAt     DateTime @default(now())

  // Business-owner relation: businesses this user owns
  ownedBusinesses Business[]        @relation("BusinessOwner")
  employeeOf      BusinessEmployee[]
  bookings        Booking[]         @relation("CustomerBookings")
  reviews         Review[]
  sentMessages    Message[]         @relation("MessageSender")
  favorites       Favorite[]
  loyaltyCards    LoyaltyCard[]
  notifications   Notification[]
  settings        UserSettings?
  smartMatches    SmartMatchRequest[]
  waitingLists    WaitingList[]
  emergencyBookings EmergencyBooking[]
  platformLoyalty PlatformLoyaltyAccount?
}

// ---------------------------------------------------------------------------
// CATEGORIES — this is what makes the platform "expandable".
// Every business category (Barbers, Plumbers, Tutors, ...) is a ROW in this
// table, not a hardcoded type in code. `attributeSchema` holds a small JSON
// spec describing category-specific fields (e.g. "car size" for Car Wash,
// "subjects taught" for Tutors). The frontend renders forms dynamically from
// this schema, so adding a new category is a data operation, not a deploy.
// ---------------------------------------------------------------------------

model Category {
  id              String   @id @default(uuid())
  name            String   @unique
  slug            String   @unique
  icon            String   @default("sparkles")
  description     String?
  // JSON string: array of { key, label, type, options? } describing
  // extra fields relevant to this category, used for both Business and
  // Service records in this category.
  attributeSchema String   @default("[]")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  businesses Business[]
  services   Service[]
  emergencyBookings EmergencyBooking[]
}

// ---------------------------------------------------------------------------
// BUSINESSES
// ---------------------------------------------------------------------------

model Business {
  id          String         @id @default(uuid())
  name        String
  description String?
  categoryId  String
  category    Category       @relation(fields: [categoryId], references: [id])
  ownerId     String
  owner       User           @relation("BusinessOwner", fields: [ownerId], references: [id])

  address     String?
  city        String?
  latitude    Float?
  longitude   Float?
  phone       String?
  email       String?

  status      String         @default("PENDING") // PENDING, APPROVED, SUSPENDED, REJECTED
  // JSON string matching the category's attributeSchema keys
  attributes  String         @default("{}")

  avgRating   Float          @default(0)
  reviewCount Int            @default(0)

  createdAt   DateTime       @default(now())

  services    Service[]
  employees   BusinessEmployee[]
  bookings    Booking[]
  reviews     Review[]
  messages    Message[]
  availability Availability[]
  favorites   Favorite[]
  loyaltyCards LoyaltyCard[]
  portfolio   PortfolioItem[]
  waitingLists WaitingList[]
  platformLoyaltyTransactions PlatformLoyaltyTransaction[]
  reviewSummary ReviewSummary?
  enhancedPortfolio EnhancedPortfolio[]
}

model BusinessEmployee {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String   @default("Staff")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([businessId, userId])
}

// Simple weekly recurring availability windows, optionally scoped to one
// employee. Used to generate bookable time slots.
model Availability {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  employeeId String? // BusinessEmployee.id, null = applies to whole business
  dayOfWeek  Int      // 0=Sunday .. 6=Saturday
  startTime  String   // "09:00"
  endTime    String   // "17:00"
}

// ---------------------------------------------------------------------------
// SERVICES — the bookable offerings within a business (e.g. "Fade Haircut",
// "Deep Clean 2BR", "Guitar Lesson 60min").
// ---------------------------------------------------------------------------

model Service {
  id              String   @id @default(uuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id])
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  name            String
  description     String?
  priceCents      Int
  durationMinutes Int      @default(60)
  attributes      String   @default("{}")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  bookings Booking[]
  waitingLists WaitingList[]
}

// ---------------------------------------------------------------------------
// BOOKINGS
// ---------------------------------------------------------------------------

model Booking {
  id           String        @id @default(uuid())
  customerId   String
  customer     User          @relation("CustomerBookings", fields: [customerId], references: [id])
  businessId   String
  business     Business      @relation(fields: [businessId], references: [id])
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id])
  employeeId   String?

  scheduledAt  DateTime
  status       String        @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED, DECLINED
  priceCents   Int
  notes        String?
  createdAt    DateTime      @default(now())

  payment  Payment?
  review   Review?
  messages Message[]
  qrCheckIn QRCheckIn?
  platformLoyaltyTransactions PlatformLoyaltyTransaction[]
}

// ---------------------------------------------------------------------------
// PAYMENTS — abstracted behind a provider interface (see src/utils/payments.js)
// so a real gateway (Stripe, Flutterwave, M-Pesa, etc.) can be dropped in.
// ---------------------------------------------------------------------------

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  booking       Booking       @relation(fields: [bookingId], references: [id])
  amountCents   Int
  method        String        @default("card")
  status        String        @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  transactionRef String?
  createdAt     DateTime      @default(now())
}

// ---------------------------------------------------------------------------
// MESSAGING — one thread per (customer, business), optionally linked to a
// specific booking.
// ---------------------------------------------------------------------------

model Message {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  customerId String
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id])
  senderId   String
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  content    String
  createdAt  DateTime @default(now())
  readAt     DateTime?
}

// ---------------------------------------------------------------------------
// REVIEWS
// ---------------------------------------------------------------------------

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  customerId String
  customer   User     @relation(fields: [customerId], references: [id])
  rating     Int
  comment    String?
  ownerReply String?
  createdAt  DateTime @default(now())
}

// ---------------------------------------------------------------------------
// FAVORITES — Users can save preferred businesses for quick access
// ---------------------------------------------------------------------------

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

// ---------------------------------------------------------------------------
// LOYALTY PROGRAM — Track customer visits and reward repeat customers
// ---------------------------------------------------------------------------

model LoyaltyCard {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  points     Int      @default(0)
  visits     Int      @default(0)
  tier       String   @default("bronze") // bronze, silver, gold, platinum
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, businessId])
}

// ---------------------------------------------------------------------------
// PORTFOLIO — Business photo galleries showcasing their work
// ---------------------------------------------------------------------------

model PortfolioItem {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  title       String?
  description String?
  imageUrl    String
  displayOrder Int     @default(0)
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS — System for email/SMS alerts on booking status changes
// ---------------------------------------------------------------------------

model Notification {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  type       String             // BOOKING_CONFIRMED, BOOKING_CANCELLED, BOOKING_REMINDER, PAYMENT_RECEIVED, NEW_REVIEW, NEW_MESSAGE
  status     String             @default("PENDING") // PENDING, SENT, FAILED
  channel    String             @default("in-app") // in-app, email, sms
  subject    String?
  message    String
  metadata   String             @default("{}")
  readAt     DateTime?
  sentAt     DateTime?
  createdAt  DateTime           @default(now())
}

// ---------------------------------------------------------------------------
// QR CODES — Quick customer check-in for employees
// ---------------------------------------------------------------------------

model QRCheckIn {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  qrCode     String   @unique
  checkedInAt DateTime?
  checkedInBy String?  // employee user id
  createdAt  DateTime @default(now())
  expiresAt  DateTime
}

// ---------------------------------------------------------------------------
// USER SETTINGS — User preferences and configuration
// ---------------------------------------------------------------------------

model UserSettings {
  id                     String  @id @default(uuid())
  userId                 String  @unique
  user                   User    @relation(fields: [userId], references: [id])
  emailNotifications     Boolean @default(true)
  smsNotifications       Boolean @default(false)
  pushNotifications      Boolean @default(true)
  language               String  @default("en")
  timezone               String  @default("UTC")
  marketingEmails        Boolean @default(false)
}

// ---------------------------------------------------------------------------
// AI SMART MATCH — Natural language service discovery
// ---------------------------------------------------------------------------

model SmartMatchRequest {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  query       String   // Natural language query: "I need a barber tomorrow after 6 PM"
  parsed      String   @default("{}") // JSON: extracted intent, category, time, budget, location
  results     String   @default("[]") // JSON: recommended business IDs with match scores
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// WAITING LIST — Customers waiting for available slots
// ---------------------------------------------------------------------------

model WaitingList {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  businessId  String
  business    Business          @relation(fields: [businessId], references: [id])
  serviceId   String?
  service     Service?          @relation(fields: [serviceId], references: [id])
  preferredDate DateTime?
  preferredTimeStart String?    // "14:00"
  preferredTimeEnd   String?    // "18:00"
  status      String            @default("ACTIVE") // ACTIVE, NOTIFIED, BOOKED, EXPIRED, CANCELLED
  notifiedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())
}

// ---------------------------------------------------------------------------
// EMERGENCY BOOKING — Urgent service requests
// ---------------------------------------------------------------------------

model EmergencyBooking {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  description   String
  location      String?
  latitude      Float?
  longitude     Float?
  maxPriceCents Int?
  status        String          @default("REQUESTED") // REQUESTED, PROVIDER_NOTIFIED, ACCEPTED, DECLINED, EXPIRED
  acceptedById  String?         // Business ID that accepted
  createdAt     DateTime        @default(now())
  expiresAt     DateTime
}

// ---------------------------------------------------------------------------
// CROSS-PLATFORM LOYALTY — Earn and redeem points across all businesses
// ---------------------------------------------------------------------------

model PlatformLoyaltyAccount {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  totalPoints      Int      @default(0)
  lifetimePoints   Int      @default(0)
  tier             String   @default("member") // member, silver, gold, platinum, diamond
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  transactions     PlatformLoyaltyTransaction[]
}

model PlatformLoyaltyTransaction {
  id          String                   @id @default(uuid())
  accountId   String
  account     PlatformLoyaltyAccount   @relation(fields: [accountId], references: [id])
  type        String                   // EARNED, REDEEMED, EXPIRED, BONUS, ADJUSTMENT
  points      Int
  businessId  String?
  business    Business?                @relation(fields: [businessId], references: [id])
  bookingId   String?
  booking     Booking?                 @relation(fields: [bookingId], references: [id])
  description String
  createdAt   DateTime                 @default(now())
}

// ---------------------------------------------------------------------------
// AI REVIEW SUMMARY — Aggregated insights from reviews
// ---------------------------------------------------------------------------

model ReviewSummary {
  id          String   @id @default(uuid())
  businessId  String   @unique
  business    Business @relation(fields: [businessId], references: [id])
  summary     String   // AI-generated summary of reviews
  sentiment   String   @default("neutral") // positive, neutral, negative
  keyTopics   String   @default("[]") // JSON array: ["punctual", "professional", "affordable"]
  strengths   String   @default("[]") // JSON array of positive highlights
  concerns    String   @default("[]") // JSON array of common concerns
  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------------------------
// ENHANCED PORTFOLIO — Support for videos, certificates, licenses
// ---------------------------------------------------------------------------

model EnhancedPortfolio {
  id          String             @id @default(uuid())
  businessId  String
  business    Business           @relation(fields: [businessId], references: [id])
  type        String             // PHOTO, VIDEO, CERTIFICATE, LICENSE, PROJECT
  title       String?
  description String?
  mediaUrl    String
  thumbnailUrl String?
  metadata    String             @default("{}") // JSON: duration for videos, issue/expiry for licenses
  displayOrder Int               @default(0)
  verified    Boolean            @default(false) // Admin verified certificates/licenses
  createdAt   DateTime           @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @default(uuid())
  email             String                  @unique
  passwordHash      String
  name              String
  phone             String?
  roles             String                  @default("[\"CUSTOMER\"]")
  currentRole       String                  @default("CUSTOMER")
  role              String                  @default("CUSTOMER")
  avatarUrl         String?
  bannedAt          DateTime?
  banReason         String?
  createdAt         DateTime                @default(now())
  bookings          Booking[]               @relation("CustomerBookings")
  ownedBusinesses   Business[]              @relation("BusinessOwner")
  employeeOf        BusinessEmployee[]
  emergencyBookings EmergencyBooking[]
  favorites         Favorite[]
  loyaltyCards      LoyaltyCard[]
  sentMessages      Message[]               @relation("MessageSender")
  notifications     Notification[]
  platformLoyalty   PlatformLoyaltyAccount?
  reviews           Review[]
  smartMatches      SmartMatchRequest[]
  settings          UserSettings?
  waitingLists      WaitingList[]
}

model Category {
  id                String             @id @default(uuid())
  name              String             @unique
  slug              String             @unique
  icon              String             @default("sparkles")
  description       String?
  attributeSchema   String             @default("[]")
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  businesses        Business[]
  emergencyBookings EmergencyBooking[]
  services          Service[]
}

model Business {
  id                          String                       @id @default(uuid())
  name                        String
  description                 String?
  categoryId                  String
  ownerId                     String
  address                     String?
  city                        String?
  latitude                    Float?
  longitude                   Float?
  phone                       String?
  email                       String?
  status                      String                       @default("PENDING")
  attributes                  String                       @default("{}")
  avgRating                   Float                        @default(0)
  reviewCount                 Int                          @default(0)
  createdAt                   DateTime                     @default(now())
  availability                Availability[]
  bookings                    Booking[]
  category                    Category                     @relation(fields: [categoryId], references: [id])
  owner                       User                         @relation("BusinessOwner", fields: [ownerId], references: [id])
  employees                   BusinessEmployee[]
  enhancedPortfolio           EnhancedPortfolio[]
  favorites                   Favorite[]
  loyaltyCards                LoyaltyCard[]
  messages                    Message[]
  platformLoyaltyTransactions PlatformLoyaltyTransaction[]
  portfolio                   PortfolioItem[]
  reviews                     Review[]
  reviewSummary               ReviewSummary?
  services                    Service[]
  waitingLists                WaitingList[]
}

model BusinessEmployee {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  title      String   @default("Staff")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([businessId, userId])
}

model Availability {
  id         String   @id @default(uuid())
  businessId String
  employeeId String?
  dayOfWeek  Int
  startTime  String
  endTime    String
  business   Business @relation(fields: [businessId], references: [id])
}

model Service {
  id              String        @id @default(uuid())
  businessId      String
  categoryId      String
  name            String
  description     String?
  priceCents      Int
  durationMinutes Int           @default(60)
  attributes      String        @default("{}")
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  bookings        Booking[]
  business        Business      @relation(fields: [businessId], references: [id])
  category        Category      @relation(fields: [categoryId], references: [id])
  waitingLists    WaitingList[]
}

model Booking {
  id                          String                       @id @default(uuid())
  customerId                  String
  businessId                  String
  serviceId                   String
  employeeId                  String?
  scheduledAt                 DateTime
  status                      String                       @default("PENDING")
  priceCents                  Int
  notes                       String?
  createdAt                   DateTime                     @default(now())
  business                    Business                     @relation(fields: [businessId], references: [id])
  customer                    User                         @relation("CustomerBookings", fields: [customerId], references: [id])
  service                     Service                      @relation(fields: [serviceId], references: [id])
  messages                    Message[]
  payment                     Payment?
  platformLoyaltyTransactions PlatformLoyaltyTransaction[]
  qrCheckIn                   QRCheckIn?
  review                      Review?
}

model Payment {
  id             String   @id @default(uuid())
  bookingId      String   @unique
  amountCents    Int
  method         String   @default("card")
  status         String   @default("PENDING")
  transactionRef String?
  createdAt      DateTime @default(now())
  booking        Booking  @relation(fields: [bookingId], references: [id])
}

model Message {
  id         String    @id @default(uuid())
  businessId String
  customerId String
  bookingId  String?
  senderId   String
  content    String
  createdAt  DateTime  @default(now())
  readAt     DateTime?
  booking    Booking?  @relation(fields: [bookingId], references: [id])
  business   Business  @relation(fields: [businessId], references: [id])
  sender     User      @relation("MessageSender", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  bookingId  String   @unique
  businessId String
  customerId String
  rating     Int
  comment    String?
  ownerReply String?
  createdAt  DateTime @default(now())
  booking    Booking  @relation(fields: [bookingId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])
  customer   User     @relation(fields: [customerId], references: [id])
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, businessId])
}

model LoyaltyCard {
  id         String   @id @default(uuid())
  userId     String
  businessId String
  points     Int      @default(0)
  visits     Int      @default(0)
  tier       String   @default("bronze")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, businessId])
}

model PortfolioItem {
  id           String   @id @default(uuid())
  businessId   String
  title        String?
  description  String?
  imageUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  business     Business @relation(fields: [businessId], references: [id])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String
  status    String    @default("PENDING")
  channel   String    @default("in-app")
  subject   String?
  message   String
  metadata  String    @default("{}")
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model QRCheckIn {
  id          String    @id @default(uuid())
  bookingId   String    @unique
  qrCode      String    @unique
  checkedInAt DateTime?
  checkedInBy String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  booking     Booking   @relation(fields: [bookingId], references: [id])
}

model UserSettings {
  id                 String  @id @default(uuid())
  userId             String  @unique
  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)
  pushNotifications  Boolean @default(true)
  language           String  @default("en")
  timezone           String  @default("UTC")
  marketingEmails    Boolean @default(false)
  user               User    @relation(fields: [userId], references: [id])
}

model SmartMatchRequest {
  id        String   @id @default(uuid())
  userId    String
  query     String
  parsed    String   @default("{}")
  results   String   @default("[]")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model WaitingList {
  id                 String    @id @default(uuid())
  userId             String
  businessId         String
  serviceId          String?
  preferredDate      DateTime?
  preferredTimeStart String?
  preferredTimeEnd   String?
  status             String    @default("ACTIVE")
  notifiedAt         DateTime?
  expiresAt          DateTime?
  createdAt          DateTime  @default(now())
  business           Business  @relation(fields: [businessId], references: [id])
  service            Service?  @relation(fields: [serviceId], references: [id])
  user               User      @relation(fields: [userId], references: [id])
}

model EmergencyBooking {
  id            String   @id @default(uuid())
  userId        String
  categoryId    String
  description   String
  location      String?
  latitude      Float?
  longitude     Float?
  maxPriceCents Int?
  status        String   @default("REQUESTED")
  acceptedById  String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  category      Category @relation(fields: [categoryId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
}

model PlatformLoyaltyAccount {
  id             String                       @id @default(uuid())
  userId         String                       @unique
  totalPoints    Int                          @default(0)
  lifetimePoints Int                          @default(0)
  tier           String                       @default("member")
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  user           User                         @relation(fields: [userId], references: [id])
  transactions   PlatformLoyaltyTransaction[]
}

model PlatformLoyaltyTransaction {
  id          String                 @id @default(uuid())
  accountId   String
  type        String
  points      Int
  businessId  String?
  bookingId   String?
  description String
  createdAt   DateTime               @default(now())
  account     PlatformLoyaltyAccount @relation(fields: [accountId], references: [id])
  booking     Booking?               @relation(fields: [bookingId], references: [id])
  business    Business?              @relation(fields: [businessId], references: [id])
}

model ReviewSummary {
  id          String   @id @default(uuid())
  businessId  String   @unique
  summary     String
  sentiment   String   @default("neutral")
  keyTopics   String   @default("[]")
  strengths   String   @default("[]")
  concerns    String   @default("[]")
  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id])
}

model EnhancedPortfolio {
  id           String   @id @default(uuid())
  businessId   String
  type         String
  title        String?
  description  String?
  mediaUrl     String
  thumbnailUrl String?
  metadata     String   @default("{}")
  displayOrder Int      @default(0)
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  business     Business @relation(fields: [businessId], references: [id])
}
